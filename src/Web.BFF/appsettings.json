{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },

  "ReverseProxy": {
    "Routes": {
      //identity
      "identity-login": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/login",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/login"
          }
        ]
      },

      "identity-register": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/register",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/register"
          }
        ]
      },

      //projects
      "project-by-id-route": {
        "ClusterId": "project-cluster",
        "Match": {
          "Path": "/api/projects/{projectId}",
          "Methods": [
            "GET",
            "PATCH",
            "DELETE"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/projects/{projectId}"
          }
        ]
      },

      "project-my-projects-route": {
        "ClusterId": "project-cluster",
        "Match": {
          "Path": "/api/my-projects",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/my-projects"
          }
        ]
      },

      "project-create-route": {
        "ClusterId": "project-cluster",
        "Match": {
          "Path": "/api/projects",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/projects"
          }
        ]
      },

      //tasks
      "tasks-by-id-route": {
        "ClusterId": "tasks-cluster",
        "Match": {
          "Path": "/api/projects/{projectId}/tasks/{taskId}",
          "Methods": [
            "GET",
            "PUT",
            "DELETE"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/projects/{projectId}/tasks/{taskId}"
          }
        ]
      },

      "tasks-collection-route": {
        "ClusterId": "tasks-cluster",
        "Match": {
          "Path": "/api/projects/{projectId}/tasks",
          "Methods": [
            "GET",
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/projects/{projectId}/tasks"
          }
        ]
      },

      //files
      "files-upload-route": {
        "ClusterId": "file-cluster",
        "Match": {
          "Path": "/api/projects/{projectId}/tasks/{taskId}/files",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/projects/{projectId}/tasks/{taskId}/files"
          }
        ]
      }
    },

    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-api": {
            "Address": "http://identity-api"
          }
        }
      },

      "project-cluster": {
        "Destinations": {
          "project-api": {
            "Address": "http://project-api"
          }
        }
      },

      "tasks-cluster": {
        "Destinations": {
          "tasks-api": {
            "Address": "http://tasks-api"
          }
        }
      },

      "file-cluster": {
        "Destinations": {
          "file-api": {
            "Address": "http://file-api"
          }
        }
      }
    }
  }
}
